<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - Courses</title>

    <link rel="stylesheet" href="/styles.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>

<body>

    <%- include('partials/navbar-' + user.role, { user: user }) %>

    <!-- Course Section -->
    <div class="container">
        <h1>Course</h1>
        <div class="course-grid">
            <% courses.forEach(course => { %>
                <div class="course-card">
                    <!-- bookmark (เฉพาะ student) -->
                    <% if(user.role === "student"){ %>
                        <form action="/bookmark/<%= course.id %>" method="POST" class="bookmark-form">
                            <button class="bookmark-btn">⭐</button>
                        </form>
                    <% } %>
                    <!-- course link -->
                    <a href="/courses/<%= course.slug %>" style="text-decoration:none; color:inherit;">
                        <% if (course.image) { %>
                        <img src="/uploads/<%= course.image %>" alt="<%= course.title %>">
                        <% } else { %>
                        <div style="aspect-ratio:16/9;background:#c5b99a;display:flex;align-items:center;justify-content:center;color:#555;font-size:13px;text-align:center;padding:8px;"><%= course.title %></div>
                        <% } %>
                        <div class="course-title">
                            <%= course.title %>
                        </div>
                    </a>
                    <!-- admin delete button -->
                    <% if(user.role === "admin"){ %>
                        <form action="/admin/deleteCourse/<%= course.id %>" method="POST"
                            onsubmit="return confirm('ลบคอร์ส <%= course.title.replace(/'/g, "\\'") %>?')"
                            style="padding: 0 12px 12px; text-align:center;">
                            <button type="submit" class="btn btn-danger" style="width:100%; font-size:13px;">🗑 ลบคอร์ส</button>
                        </form>
                    <% } %>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>