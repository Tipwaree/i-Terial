<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - Courses</title>

    <link rel="stylesheet" href="/styles.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>

<body>

    <!-- Navbar -->
    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>

        <div class="buttongroup">
            <a href="/home"><button>Home</button></a>
            <a href="/courses"><button>Search</button></a>
            <a href="/profile"><button>Profile</button></a>
            <a href="/exam"><button>Exam</button></a>
            <a href="/review"><button>Review</button></a>
        </div>
    </div>

    <!-- Course Section -->
    <div class="container">
        <h1>Course</h1>
        <div class="course-grid">
            <% courses.forEach(course => { %>
                <div class="course-card">
                    <!-- bookmark (เฉพาะ student) -->
                    <% if(user.role === "student"){ %>
                        <form action="/bookmark/<%= course.id %>" method="POST" class="bookmark-form">
                            <button class="bookmark-btn">⭐</button>
                        </form>
                    <% } %>
                    <!-- course link -->
                    <a href="/courses/<%= course.slug %>" style="text-decoration:none; color:inherit;">
                        <img src="/uploads/<%= course.image %>" alt="<%= course.title %>">
                        <div class="course-title">
                            <%= course.title %>
                        </div>
                    </a>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>