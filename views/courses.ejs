<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - Courses</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
        rel="stylesheet">
</head>

<body>

    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">
            <a href="/home"><button>Home</button></a>
            <a href="/courses"><button>Search</button></a>
            <a href="/profile"><button>Profile</button></a>
            <a href="/exam"><button>Exam</button></a>
            <a href="/review"><button>Review</button></a>
        </div>
    </div>

    <div class="container">
        <h1>Course</h1>
        <div class="course-grid">
            <% courses.forEach(course=> { %>
                <div class="course-card">
                    <img src="/uploads/<%= course.image %>" alt="<%= course.title %>">
                    <div class="course-title">
                        <%= course.title %>
                    </div>
                    <% if(user.role==="student" ){ %>
                        <form action="/bookmark/<%= course.id %>" method="POST">
                            <button class="bookmark-btn">⭐</button>
                        </form>
                        <% } %>
                </div>
                <% }); %>
        </div>
    </div>
</body>

</html>