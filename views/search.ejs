<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - Search</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/navbar-' + (user ? user.role : 'guest'), { user: user || {} }) %>

    <div class="container">
        <h1>ค้นหาคอร์ส</h1>

        <form action="/search" method="GET" style="text-align:center; margin-bottom:30px;">
            <input type="text" name="keyword" placeholder="กรุณากรอกชื่อรายวิชา" value="<%= keyword %>"
                style="padding:10px 16px; border-radius:10px; border:2px solid #aaa; font-size:15px; font-family:inherit; width:300px;">
            <button type="submit" style="padding:10px 18px; margin-left:8px; border-radius:10px; border:none; background:#7f9c34; color:white; font-size:15px; cursor:pointer;">🔍 ค้นหา</button>
        </form>

        <% if (courses === null) { %>
            <!-- ยังไม่ได้ค้นหา -->
        <% } else if (courses.length === 0) { %>
            <p style="text-align:center; color:#888;">ไม่พบคอร์สที่ค้นหา</p>
        <% } else { %>
            <div class="course-grid">
                <% courses.forEach(course => { %>
                    <div class="course-card">
                        <a href="/courses/<%= course.slug %>" style="text-decoration:none; color:inherit;">
                            <img src="/uploads/<%= course.image %>" alt="<%= course.title %>">
                            <div class="course-title"><%= course.title %></div>
                        </a>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

</body>
</html>
