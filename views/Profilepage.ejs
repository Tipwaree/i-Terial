<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Page</title>

    <link rel="stylesheet" href="/styles.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:wght@200;300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>

<body>
    <!-- Navbar -->
    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">

            <a href="/home">
                <button class="highbut">Home</button>
            </a>

            <a href="/courses">
                <button class="highbut">Search</button>
            </a>

            <a href="/profile">
                <button class="highbut">Profile</button>
            </a>

            <a href="/exam">
                <button class="highbut">Exam</button>
            </a>

            <a href="/review">
                <button class="highbut">Review</button>
            </a>

        </div>

    </div>


    <!-- Profile Section -->
    <div class="profilecontainer">

        <div class="profilelogo">
            <h1>Profile</h1>
        </div>

        <div class="profilecontent">

            <!-- Left Info -->
            <div class="left-information">

                <div class="left">

                    <p>Username</p>
                    <label><%= user.username %></label>

                    <p>Email</p>
                    <label><%= user.email %></label>

                    <p>Phone</p>
                    <label><%= user.phone %></label>

                    <p>Address</p>
                    <label><%= user.address %></label>

                    <p>Gender</p>
                    <label><%= user.gender %></label>

                </div>

            </div>

            <!-- Profile Image -->
            <div class="right-information">

                <div class="image">
                    <img src="<%= user.image ? '/uploads/' + user.image : '/images/profile.jpg' %>">
                </div>

            </div>

        </div>

        <!-- Buttons -->
        <div class="profilebuttons">

            <a href="/profile/edit">
                <button class="editbtn">Edit</button>
            </a>

            <a href="/logout">
                <button class="logoutbtn">Logout</button>
            </a>

        </div>

    </div>


    <!-- Bookmark Section (เฉพาะ student) -->
    <% if(user.role === "student"){ %>

    <div class="bookmark">

        <h3>My Bookmarks</h3>

        <div class="course-grid">

            <% bookmarks.forEach(course => { %>

                <a href="/courses/<%= course.slug %>" style="text-decoration:none; color:inherit;">

                    <div class="course-card">

                        <img src="/uploads/<%= course.image %>" alt="<%= course.title %>">

                        <div class="course-title">
                            <%= course.title %>
                        </div>

                    </div>

                </a>

            <% }) %>

        </div>

    </div>

    <% } %>

</body>
</html>