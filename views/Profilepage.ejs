<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Page</title>

    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
        rel="stylesheet">

</head>

<body>
    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">
            <a href="/home">
                <button class="highbut">Home</button>
            </a>
            <a href="/search">
                <button class="highbut">Search</button>
            </a>
            <a href="/profile">
                <button class="highbut">Profile</button>
            </a>

            <a href="/exam">
                <button class="highbut">Exam</button>
            </a>
            <a href="/review">
                <button class="highbut">Review</button>
            </a>
        </div>
    </div>

    <div class="profilecontainer">

        <div class="profilelogo">
            <h1>Profile</h1>
        </div>

        <div class="profilecontent">

            <!-- ข้อมูล -->
            <div class="left-information">
                <div class="left">
                    <p>Username</p> <label>
                        <%= user.username %>
                    </label>
                    <p>Email</p> <label>
                        <%= user.email %>
                    </label>
                    <p>Phone</p> <label>
                        <%= user.phone %>
                    </label>
                    <p>Address</p> <label>
                        <%= user.address %>
                    </label>
                    <p>Gender</p> <label>
                        <%= user.gender %>
                    </label>
                </div>
            </div>

            <!-- รูป -->
            <div class="right-information">
                <div class="image">
                    <img src="<%= user.image ? '/uploads/' + user.image : '/images/profile.jpg' %>">
                </div>
            </div>

        </div>

        <!-- ปุ่ม -->
        <div class="profilebuttons">
            <a href="/profile/edit">
                <button class="editbtn">Edit</button>
            </a>

            <a href="/logout">
                <button class="logoutbtn">Logout</button>
            </a>
        </div>

    </div>

    <div class="bookmark">
        <h2>My Bookmarks</h2>

        <div class="course-grid">
            <% bookmarks.forEach(course=> { %>

                <div class="course-card">
                    <img src="/uploads/<%= course.image %>">
                    <div class="course-title">
                        <%= course.title %>
                    </div>
                </div>

                <% }) %>
        </div>
    </div>
</body>

</html>