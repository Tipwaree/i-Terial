<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Lessons - i-Terial</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">
            <a href="/home"><button>Home</button></a>
            <a href="/courses"><button>Search</button></a>
            <% if (user) { %>
                <a href="/profile"><button>Profile</button></a>
                <% if (user.role === 'teacher' || user.role === 'admin') { %>
                    <a href="/teacher/create-course"><button>Create Course</button></a>
                <% } %>
            <% } %>
            <a href="/student"><button>Exam</button></a>
            <a href="/review"><button>Review</button></a>
        </div>
    </div>

    <div class="lesson-container">
        <h2>จัดการบทเรียน: <%= course.title %></h2>
        <a href="/courses/<%= course.slug %>" class="btn btn-secondary" style="margin-bottom: 20px;">กลับไปหน้าคอร์ส</a>

        <div style="background: #f9f9f9; padding: 20px; border-radius: 8px;">
            <h3>เพิ่มบทเรียนใหม่</h3>
            <form action="/teacher/add-lesson/<%= course.id %>" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label>ชื่อบทเรียน (Title):</label>
                    <input type="text" name="title" required placeholder="เช่น บทที่ 1: แนะนำวิชา">
                </div>
                <div class="form-group">
                    <label>ไฟล์เอกสาร (PDF):</label>
                    <input type="file" name="pdf" accept="application/pdf">
                </div>
                <div class="form-group">
                    <label>ไฟล์วิดีโอ (Video):</label>
                    <input type="file" name="video" accept="video/*">
                </div>
                <button type="submit" class="btn btn-primary">บันทึกบทเรียน</button>
            </form>
        </div>

        <div class="lesson-list">
            <h3>บทเรียนทั้งหมด (<%= lessons.length %> บทเรียน)</h3>
            <% if (lessons.length === 0) { %>
                <p style="color: #888;">ยังไม่มีบทเรียนในคอร์สนี้</p>
            <% } else { %>
                <% lessons.forEach((lesson, index) => { %>
                    <div class="lesson-item">
                        <h4 style="margin: 0 0 10px 0;"><%= index + 1 %>. <%= lesson.title %></h4>
                        <div>
                            <% if (lesson.pdf_file) { %>
                                <a href="/uploads/<%= lesson.pdf_file %>" target="_blank" class="btn btn-secondary" style="font-size: 12px; margin-right: 5px;">📄 ดู PDF</a>
                            <% } %>
                            <% if (lesson.video_file) { %>
                                <a href="/uploads/<%= lesson.video_file %>" target="_blank" class="btn btn-secondary" style="font-size: 12px;">🎬 ดูวิดีโอ</a>
                            <% } %>
                            <% if (!lesson.pdf_file && !lesson.video_file) { %>
                                <span style="font-size: 12px; color: #888;">(ไม่มีไฟล์แนบ)</span>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

</body>
</html>