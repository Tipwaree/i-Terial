<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Course - i-Terial</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
        rel="stylesheet">

    <style>
        /* จัดการสไตล์ฟอร์มให้เข้ากับฟอนต์และธีมเว็บ */
        body {
            font-family: 'Kodchasan', sans-serif;
        }

        .course-container {
            background-color: rgba(255, 255, 255, 0.95);
            max-width: 600px;
            margin: 40px auto;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .course-container h2 {
            margin-bottom: 25px;
            color: #333;
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #444;
        }

        .form-group input[type="text"],
        .form-group textarea,
        .form-group input[type="file"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-family: 'Kodchasan', sans-serif;
            /* ให้ input ใช้ฟอนต์เดียวกัน */
            box-sizing: border-box;
            font-size: 14px;
        }

        .submit-btn {
            background-color: #4CAF50;
            color: white;
            padding: 12px 20px;
            border: none;
            border-radius: 5px;
            font-family: 'Kodchasan', sans-serif;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-top: 15px;
            transition: background-color 0.3s ease;
        }

        .submit-btn:hover {
            background-color: #45a049;
        }
    </style>
</head>

<body>

    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">
            <a href="/home"><button>Home</button></a>
            <a href="/courses"><button>Search</button></a>
            <% if (user) { %>
                <a href="/profile"><button>Profile</button></a>
                <% if (user.role==='teacher' || user.role==='admin' ) { %>
                    <a href="/teacher/create-course"><button style="background-color: #ddd; color: #333;">Create
                            Course</button></a>
                    <% } %>
                        <% } %>
                            <a href="/exam"><button>Exam</button></a>
                            <a href="/review"><button>Review</button></a>
        </div>
    </div>

    <div class="course-container">
        <h2>แก้ไขคอร์สเรียน: <%= course.title %>
        </h2>
        <form action="/teacher/edit-course/<%= course.id %>" method="POST" enctype="multipart/form-data">
            <label>ชื่อคอร์ส:</label>
            <input type="text" name="title" value="<%= course.title %>" required>

            <label>รายละเอียด:</label>
            <textarea name="description" required><%= course.description %></textarea>

            <label>รูปภาพปกใหม่ (ถ้าไม่เปลี่ยนไม่ต้องอัปโหลด):</label>
            <input type="file" name="image" accept="image/*">

            <button type="submit">บันทึกการแก้ไข</button>
        </form>
    </div>

</body>

</html>