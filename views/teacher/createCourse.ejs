<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>สร้างคอร์สเรียน - i-Terial</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
    <style>
        .file-label {
            display: block;
            background: rgba(255,255,255,0.92);
            border-radius: 8px;
            padding: 10px 12px;
            cursor: pointer;
            font-size: 14px;
            color: #555;
            margin-bottom: 14px;
        }
        .file-label input[type="file"] { display: none; }
        #file-name { font-style: italic; color: #888; margin-left: 6px; }
    </style>
</head>
<body>

    <%- include('../partials/navbar-' + user.role, { user: user }) %>

    <div class="auth-page">
        <div class="loginform" style="width: 520px;">
            <h1 style="font-size: 28px;">สร้างคอร์สเรียนใหม่</h1>

            <% if (typeof error !== 'undefined' && error) { %>
                <p style="color:#ffe0d0; background:rgba(0,0,0,0.15); padding:10px; border-radius:8px; text-align:center;">
                    เกิดข้อผิดพลาด กรุณาลองใหม่อีกครั้ง
                </p>
            <% } %>

            <form action="/teacher/create-course" method="POST" enctype="multipart/form-data">
                <p>ชื่อคอร์ส</p>
                <input type="text" name="title" placeholder="เช่น ติวเข้มก่อนสอบ TCAS" required>

                <p>รายละเอียดคอร์ส</p>
                <textarea name="description" rows="4" placeholder="อธิบายเนื้อหาคอร์สเรียน..." required
                    style="width:100%; padding:10px 12px; border-radius:8px; border:none; outline:none;
                           font-family:'Kodchasan',sans-serif; font-size:15px; color:#333;
                           background:rgba(255,255,255,0.92); resize:vertical; box-sizing:border-box; margin-bottom:14px;"></textarea>

                <p>รูปภาพปกคอร์ส</p>
                <label class="file-label" for="image">
                    📁 เลือกรูปภาพ <span id="file-name">ยังไม่ได้เลือกไฟล์</span>
                    <input type="file" id="image" name="image" accept="image/*"
                        onchange="document.getElementById('file-name').textContent = this.files[0]?.name || 'ยังไม่ได้เลือกไฟล์'">
                </label>

                <div class="submitbutton">
                    <button type="submit">สร้างคอร์ส</button>
                </div>
            </form>

            <div style="text-align:center; margin-top:14px;">
                <a href="/courses" style="color:var(--bg); font-size:14px; opacity:0.85;">← กลับไปหน้าคอร์ส</a>
            </div>
        </div>
    </div>

</body>
</html>