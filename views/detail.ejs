<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - <%= course.title %>
    </title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Kodchasan:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
        rel="stylesheet">
</head>

<body>

    <div class="bigcontainer">
        <div class="logo">
            <h1>i-Terial</h1>
        </div>
        <div class="buttongroup">
            <a href="/home"><button>Home</button></a>
            <a href="/courses"><button>Search</button></a>

            <% if (typeof user !=='undefined' && user) { %>
                <a href="/profile"><button>Profile</button></a>
                <% if (user.role==='teacher' || user.role==='admin' ) { %>
                    <a href="/teacher/create-course"><button>Create Course</button></a>
                    <% } %>
                        <% } %>

                            <a href="/student"><button>Exam</button></a>
                            <a href="/review"><button>Review</button></a>
        </div>
    </div>

    <div class="container">
        <div class="detail-layout">

            <div class="sidebar">
                <div class="course-card">
                    <img src="/uploads/<%= course.image %>" alt="<%= course.title %>" class="detail-course-img">
                    <div class="detail-course-title">
                        <%= course.title %>
                    </div>
                </div>

                <div style="margin: 20px 0;">
                    <button class="btn-bookmark">Bookmark</button>
                    <button class="btn-enroll">Enroll</button>
                </div>

                <div class="detail-sidebar-info">
                    <p><strong>ผู้สอน :</strong>
                        <%= course.teacher %>
                    </p>
                    <p><strong>จำนวนผู้เรียน :</strong>
                        <%= course.students %> คน
                    </p>
                    <p><strong>คะแนน :</strong>
                        <%= course.rating %> / 5.0
                    </p>
                    <p><strong>รีวิว :</strong>
                        <%= course.reviewText %>
                    </p>
                    <p><strong>บันทึกการเรียน :</strong>
                        <%= course.progress %>%
                    </p>
                </div>
            </div>

            <div class="main-content">

                <div class="detail-content-box">
                    <h2 class="detail-main-title">
                        <%= course.title %>
                    </h2>
                    <p class="detail-description">
                        <%= course.description %>
                    </p>
                </div>

                <% if (typeof user !=='undefined' && user && (user.role==='admin' || user.role==='teacher' )) { %>
                    <div class="teacher-menu">
                        <h4 class="teacher-menu-title">เมนูจัดการคอร์ส (สำหรับผู้สอน)</h4>
                        <a href="/teacher/edit-course/<%= course.id %>">
                            <button class="btn-teacher btn-edit-course">แก้ไขรายละเอียดคอร์ส</button>
                        </a>
                        <a href="/teacher/manage-lessons/<%= course.id %>">
                            <button class="btn-teacher btn-manage-lessons">เพิ่ม/ลบบทเรียน</button>
                        </a>
                    </div>
                    <% } %>

                        <div class="lesson-section">
                            <h3 class="lesson-section-title">
                                เนื้อหาบทเรียนทั้งหมด (<%= lessons ? lessons.length : 0 %> บท)
                            </h3>

                            <% if (!lessons || lessons.length===0) { %>
                                <div class="lesson-empty">
                                    <p>ยังไม่มีบทเรียนในคอร์สนี้</p>
                                    <p style="font-size: 14px;">(ผู้สอนสามารถกดปุ่ม "เพิ่ม/ลบบบทเรียน"
                                        ด้านบนเพื่อเพิ่มเนื้อหาได้เลย)</p>
                                </div>
                                <% } else { %>
                                    <div class="lesson-list-container">
                                        <% lessons.forEach((lesson, index)=> { %>
                                            <div class="lesson-row">

                                                <div class="lesson-name">
                                                    บทที่ <%= index + 1 %>: <%= lesson.title %>
                                                </div>

                                                <div class="lesson-actions">
                                                    <% if (lesson.pdf_file) { %>
                                                        <a href="/uploads/<%= lesson.pdf_file %>" target="_blank">
                                                            <button class="btn-lesson btn-pdf">📄 เอกสาร PDF</button>
                                                        </a>
                                                        <% } %>

                                                            <% if (lesson.video_file) { %>
                                                                <a href="/uploads/<%= lesson.video_file %>"
                                                                    target="_blank">
                                                                    <button class="btn-lesson btn-video">🎬
                                                                        วิดีโอเรียน</button>
                                                                </a>
                                                                <% } %>

                                                                    <% if (!lesson.pdf_file && !lesson.video_file) { %>
                                                                        <span
                                                                            class="lesson-no-file">(ไม่มีไฟล์แนบ)</span>
                                                                        <% } %>
                                                </div>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <% } %>
                        </div>
            </div>
        </div>
    </div>

</body>

</html>