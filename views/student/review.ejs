<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i-Terial - Review</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kodchasan:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <%- include('../partials/navbar-' + user.role, { user: user }) %>

    <div class="review-container">

        <h1><%= course.title %></h1>
        <p>ผู้สอน: <%= course.teacher %></p>

        <div class="avg-rating">
            ⭐ คะแนนเฉลี่ย: <%= avgRating ? avgRating.toFixed(1) : "0.0" %> / 5.0
        </div>

        <!-- STUDENT: เขียนรีวิว -->
        <% if (role === "student") { %>
            <form action="/review/<%= courseId %>" method="POST" class="review-form">

                <div class="star-rating">
                    <input type="radio" id="star5" name="rating" value="5">
                    <label for="star5">★</label>
                    <input type="radio" id="star4" name="rating" value="4">
                    <label for="star4">★</label>
                    <input type="radio" id="star3" name="rating" value="3">
                    <label for="star3">★</label>
                    <input type="radio" id="star2" name="rating" value="2">
                    <label for="star2">★</label>
                    <input type="radio" id="star1" name="rating" value="1">
                    <label for="star1">★</label>
                </div>

                <div class="review-input">
                    <textarea name="comment" placeholder="เขียนรีวิวของคุณ..." required></textarea>
                    <br><br>
                    <button type="submit">ส่งรีวิว</button>
                </div>

            </form>
        <% } %>

        <!-- รายการรีวิว -->
        <div class="review-list">

            <% if (reviews.length === 0) { %>
                <p style="color:#888;">ยังไม่มีรีวิว</p>
            <% } %>

            <% reviews.forEach(r => { %>
                <div class="review-card">

                    <div class="rating">
                        <% let stars = r.rating || 0 %>
                        <% for (let i = 0; i < stars; i++) { %>★<% } %>
                        <% for (let i = stars; i < 5; i++) { %>☆<% } %>
                        <% if (r.username) { %>
                            <span style="font-size:13px; color:#666; margin-left:8px;">— <%= r.username %></span>
                        <% } %>
                    </div>

                    <p><%= r.review_text %></p>

                    <!-- ADMIN: ลบรีวิว -->
                    <% if (role === "admin") { %>
                        <form action="/review/delete/<%= r.id %>" method="POST" style="display:inline;">
                            <button class="delete-btn" onclick="return confirm('ลบรีวิวนี้?')">🗑 ลบ</button>
                        </form>
                    <% } %>

                </div>
            <% }); %>

        </div>

        <div style="margin-top:20px;">
            <a href="/courses/<%= course.slug %>">← กลับไปหน้าคอร์ส</a>
        </div>

    </div>

</body>
</html>
